{
  "manifest_version": 3,
  "name": "Riko Chrome Companion",
  "version": "1.1.0",
  "description": "A chrome companion that lives in your browser — drag her around, chat with her, and she'll talk back",
  "permissions": ["storage"],
  "host_permissions": [
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "icons": {
    "128": "icons/icon.png"
  },
  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "assets/*.webp",
        "options/help.html",
        "options/options.css"
      ],
      "matches": ["<all_urls>"]
    }
  ]
}
